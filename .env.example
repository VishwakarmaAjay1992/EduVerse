# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=info

# Canonical public site URL (used by sitemap.xml, robots.txt, and Open Graph
# tags). On Vercel, set this to your production domain. VERCEL_URL is used
# automatically for preview deploys if this is unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Database (PostgreSQL) — optional in Phase 1 ────────────────────────────
# The static content site does not require a database. Uncomment and set when
# Phase 2 (auth + persistent progress) lands.
# DATABASE_URL=postgresql://eduverse:eduverse@localhost:5432/eduverse?schema=public

# ─── Cache (Redis) — optional in Phase 1 ────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Authentication — optional in Phase 1 ──────────────────────────────────
# Required only when auth helpers are actually used. Must be 16+ characters.
# JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
# JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ─── Media (Cloudinary) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email ──────────────────────────────────────────────────────────────────
EMAIL_FROM=no-reply@eduverse.local
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASSWORD=

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
